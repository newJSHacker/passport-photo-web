# Local dev: Next.js proxies /api/backend/* to the FastAPI service.
NEXT_PUBLIC_API_URL=/api/backend
API_URL=http://localhost:8000

# Render (web service): keep NEXT_PUBLIC_API_URL=/api/backend and set API_URL to your
# API service URL with NO trailing slash, e.g. https://passport-api.onrender.com
#
# Optional: server-side site URL fallback for checkout redirects
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
#
# Render (direct browser → API): set NEXT_PUBLIC_API_URL=https://passport-api.onrender.com/api/v1
# (no trailing slash)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SESSION_TOKEN=change-this-to-a-long-random-string

# Pre-fill checkout payment step with test email/card (dev enables this automatically)
# NEXT_PUBLIC_CHECKOUT_TEST_PREFILL=true
